[sub_resource type="SphereShape3D" id="SphereShape3D_i5arm"]
radius = 0.69

[sub_resource type="GDScript" id="GDScript_i5arm"]
script/source = "extends Node3D

@onready var path_follow_3d: PathFollow3D = $\"../../..\"
@onready var pivot: Node3D = $\"..\"
@onready var animation_player: AnimationPlayer = $AnimationPlayer


var vida = 2
var speed = 0.1
var alvo
enum estado {andar,atacar,morto}
var state = estado.andar

func _process(delta: float) -> void:
	match state:
		estado.andar:
			animation_player.play(\"Walk\")
			path_follow_3d.progress_ratio += speed * delta
			#pivot.rotation_degrees = Vector3(0,0,0)
		estado.atacar:
			animation_player.play(\"Attack\")
			print(global_position)
		
	




func _on_body_entered(body: Node3D) -> void:
	if body.is_in_group(\"player\"):
		state = estado.atacar
		
	pass # Replace with function body.


func _on_body_exited(body: Node3D) -> void:
	if body.is_in_group(\"player\"):
		alvo = body
		state = estado.andar
	pass # Replace with function body.
"

